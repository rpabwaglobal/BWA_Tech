# Copie para `.env` na RAIZ do repositório (ao lado de docker-compose.yml).
# O Docker não usa frontend/.env.production nem backend/.env dentro da imagem (.dockerignore).
#
# Traefik (Hostinger): rede Docker externa "web" (verifique com docker inspect no contentor traefik).
#   PUBLIC_HOST = Host(...) do router; TRAEFIK_CERT_RESOLVER ex.: letsencrypt
# Produção HTTPS no .env: BEHIND_HTTPS_PROXY=true

# --- Traefik (rede externa "web" na VPS) ---
PUBLIC_HOST=tech.bwa.global
TRAEFIK_NETWORK=web
TRAEFIK_CERT_RESOLVER=letsencrypt
BEHIND_HTTPS_PROXY=true
HOST_BIND=127.0.0.1

# Postgres (compose) — gere senha forte: openssl rand -base64 32
POSTGRES_DB=bwaproj_db
POSTGRES_USER=bwaproj
POSTGRES_PASSWORD=CHANGEME_GENERATE_STRONG_PASSWORD

# Django dentro do container — ligação a db/redis (nomes dos serviços do compose)
USE_POSTGRES=true
DB_HOST=db
DB_PORT=5432
DB_NAME=bwaproj_db
DB_USER=bwaproj
DB_PASSWORD=CHANGEME_GENERATE_STRONG_PASSWORD
CHANNEL_LAYER_BACKEND=redis
REDIS_HOST=redis
REDIS_PORT=6379
# Senha do Redis — gerar: openssl rand -base64 32 — embuti-la nas URLs do Celery
REDIS_PASSWORD=CHANGEME_REDIS_PASSWORD
CELERY_BROKER_URL=redis://:CHANGEME_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGEME_REDIS_PASSWORD@redis:6379/0

# Django (serviço backend) — gerar: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGEME_GENERATE_DJANGO_SECRET_KEY
DEBUG=False
# Se expuser :8000 no IP público inclua também IP e IP:8000 (ver comentários no exemplo).
ALLOWED_HOSTS=localhost,127.0.0.1,tech.bwa.global,187.77.53.184,187.77.53.184:8000
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://tech.bwa.global,http://187.77.53.184:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://tech.bwa.global,http://187.77.53.184:8000

# Portal — Django usa estas credenciais no servidor para obter JWT ao repassar pedidos /api/portal-formularios/
PORTAL_BASE_URL=https://api.bwa.global:3334
PORTAL_USERNAME=
PORTAL_PASSWORD=

# Build Vite — escolha UM dos modos de formulários/suporte:

# A) HTTPS público (browser chama o portal direto — o portal tem de permitir CORS à origem do SPA)
# VITE_API_URL=https://tech.bwa.global/api
# VITE_WS_URL=wss://tech.bwa.global
# VITE_FORMULARIOS_PROXY_THROUGH_DJANGO=false
# VITE_FORMULARIOS_API_BASE=https://api.bwa.global:3334/api/formularios
# VITE_FORMULARIOS_TOKEN_FROM_PORTAL=true

# B) LAN / HTTP sem CORS no portal — Django faz proxy (mesma origem que VITE_API_URL)
# VITE_API_URL=http://192.168.x.x:8001/api
# VITE_WS_URL=ws://192.168.x.x:8001
# VITE_FORMULARIOS_PROXY_THROUGH_DJANGO=true
# VITE_FORMULARIOS_TOKEN_FROM_PORTAL=false
# (omitir ou deixar vazio VITE_FORMULARIOS_API_BASE)

VITE_API_URL=https://tech.bwa.global/api
VITE_WS_URL=wss://tech.bwa.global
VITE_FORMULARIOS_USE_PROXY=false
VITE_FORMULARIOS_PROXY_THROUGH_DJANGO=false
VITE_FORMULARIOS_API_BASE=https://api.bwa.global:3334/api/formularios
VITE_FORMULARIOS_TOKEN_FROM_PORTAL=true
