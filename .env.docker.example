# Copie para `.env` na RAIZ do repositório (ao lado de docker-compose.yml).
# O Docker não usa frontend/.env.production nem backend/.env dentro da imagem (.dockerignore).

# Postgres (compose)
POSTGRES_DB=bwaproj_db
POSTGRES_USER=bwaproj
POSTGRES_PASSWORD=bwaproj_secret

# Django (serviço backend)
SECRET_KEY=altere-em-producao-uma-chave-longa-e-aleatoria
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,bwatech.com.br,www.bwatech.com.br
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://bwatech.com.br,https://www.bwatech.com.br
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://bwatech.com.br,https://www.bwatech.com.br

# Portal (JWT suporte — mesmo significado que backend/.env em desenvolvimento)
PORTAL_BASE_URL=https://api.bwa.global:3334
PORTAL_USERNAME=
PORTAL_PASSWORD=

# Build Vite no Dockerfile (obrigatório VITE_FORMULARIOS_API_BASE em produção)
VITE_API_URL=https://bwatech.com.br/api
VITE_WS_URL=wss://bwatech.com.br
VITE_FORMULARIOS_USE_PROXY=false
VITE_FORMULARIOS_API_BASE=https://api.bwa.global:3334/api/formularios
VITE_FORMULARIOS_TOKEN_FROM_PORTAL=true

# LAN (IP interno): troque VITE_* para http://192.168.x.x:PORTA e ws://...
# e acrescente o IP em ALLOWED_HOSTS / CORS / CSRF (ou use ./deploy.sh).
