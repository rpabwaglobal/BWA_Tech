# Copie para backend/.env:  copy .env.example .env  (PowerShell na pasta backend)
# Desenvolvimento: pode deixar ALLOWED_HOSTS e CORS em branco (usa padrões locais).
# Produção: defina SECRET_KEY, DEBUG=False, ALLOWED_HOSTS e CORS.

# --- Banco: Postgres no Docker (dump restaurado) + runserver local ---
# Com docker compose up -d db e porta 5432 publicada, use estes valores (iguais ao compose):
USE_POSTGRES=true
DB_NAME=bwaproj_db
DB_USER=bwaproj
DB_PASSWORD=bwaproj_secret
DB_HOST=127.0.0.1
# Porta no host = mapeamento do docker-compose (padrão 5433; Postgres nativo no Windows usa 5432)
DB_PORT=5433

# Sem USE_POSTGRES=true o Django usa SQLite (db.sqlite3), ignorando o dump no Postgres.

# --- Portal (JWT Bearer para APIs externas, ex.: /api/autenticacao/obter-token-acesso/) ---
# Copie para backend/.env com valores reais; não commitar .env.
#
# Na documentação de suporte aparece {HOST} (ex.: https://api.seudominio.com).
# PORTAL_BASE_URL deve ser esse MESMO host (sem barra no final): é de lá que saem
#   POST /api/autenticacao/obter-token-acesso/
#   GET  /api/formularios/suporte/por-usuario/
#
# PORTAL_BASE_URL=https://api.seudominio.com
# PORTAL_USERNAME=email-do-servico@exemplo.com
# PORTAL_PASSWORD=

# JWT para o SPA chamar a API externa de formulários (usuário precisa estar logado no app).
# GET http://127.0.0.1:8000/api/portal/formularios-access/ → {"access":"..."}

# Produção
# SECRET_KEY=uma-chave-longa-e-aleatoria
# DEBUG=False
# ALLOWED_HOSTS=tech.bwa.global
# CORS_ALLOWED_ORIGINS=https://tech.bwa.global
# CSRF_TRUSTED_ORIGINS=https://tech.bwa.global
