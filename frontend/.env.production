# Build de produção. O .dockerignore tem `!frontend/.env.production` pra esse
# arquivo entrar no build Docker e o Vite usar automaticamente durante
# `npx vite build`.

VITE_API_URL=https://tech.bwa.global/api
VITE_WS_URL=wss://tech.bwa.global

# Chamados/Kanban de suporte: Django proxia ao portal (mesma origem, sem CORS).
# O servidor (PortalFormulariosProxyView em apps/formularios/portal_proxy_views.py)
# obtém o Bearer JWT do portal e repassa as requisições — o browser nunca fala
# direto com api.bwa.global. Pré-requisito: PORTAL_BASE_URL definido no .env do
# backend em produção.
VITE_FORMULARIOS_USE_PROXY=false
VITE_FORMULARIOS_PROXY_THROUGH_DJANGO=true
