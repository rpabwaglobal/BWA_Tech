# Build de produção: npm run build (fora do Docker).
# No Docker, o build usa o .env na RAIZ do repo (variáveis VITE_* passadas como build args).

VITE_API_URL=https://tech.bwa.global/api
VITE_WS_URL=wss://tech.bwa.global

VITE_FORMULARIOS_USE_PROXY=false
VITE_FORMULARIOS_API_BASE=https://api.bwa.global:3334/api/formularios
VITE_FORMULARIOS_TOKEN_FROM_PORTAL=true
