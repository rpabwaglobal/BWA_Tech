# Copie para .env.production e ajuste com seu domínio.
# Usado no build: npm run build
# Deixe em branco para usar o mesmo domínio da página (recomendado quando front e API estão no mesmo host).

# Base da API (com /api no final)
VITE_API_URL=https://bwatech.com.br/api

# Base do WebSocket (sem /ws) - use wss:// em produção
VITE_WS_URL=wss://bwatech.com.br

# --- API de formulários / suporte (Kanban = sempre esta API do portal; não o BD Django) ---
# Obrigatório em produção: URL base até .../formularios (sem barra no fim).
# Timeline/comentários usam VITE_API_URL + /formularios/suporte-timeline/ no Django.
# VITE_FORMULARIOS_API_BASE=https://seu-host.com/api/formularios
# Autenticação: token = Authorization: Token … (igual ao resto da app) | bearer = JWT Bearer …
# VITE_FORMULARIOS_AUTH_SCHEME=token
# Chave no localStorage do token (padrão: auth_token)
# VITE_FORMULARIOS_AUTH_TOKEN_KEY=auth_token
# Caminho do catálogo de suporte (tipo/itens/motivos), relativo à base de formularios — padrão suporte/catalogo/
# VITE_FORMULARIOS_SUPORTE_CATALOGO_PATH=suporte/catalogo/

# API externa de formulários/suporte (portal): URL direta em produção (CORS deve permitir seu domínio).
VITE_FORMULARIOS_USE_PROXY=false
VITE_FORMULARIOS_API_BASE=https://api.bwa.global:3334/api/formularios

# Em desenvolvimento use frontend/.env.development (proxy Vite em /__formularios).

# true = Bearer JWT obtido no backend em GET /api/portal/formularios-access/ (login portal via PORTAL_* no backend/.env)
VITE_FORMULARIOS_TOKEN_FROM_PORTAL=true
