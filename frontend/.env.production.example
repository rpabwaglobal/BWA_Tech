# Copie para .env.production e ajuste com seu domínio.
# Usado no build: npm run build
# Deixe em branco para usar o mesmo domínio da página (recomendado quando front e API estão no mesmo host).

# Base da API (com /api no final)
VITE_API_URL=https://tech.bwa.global/api

# Base do WebSocket (sem /ws) - use wss:// em produção
VITE_WS_URL=wss://tech.bwa.global

# --- Suporte / Kanban (API do portal; BD Django só para timeline em /api/formularios/suporte-timeline/) ---
#
# Modo 1 — Browser chama o portal em HTTPS (exige CORS no portal para a origem do SPA):
# VITE_FORMULARIOS_PROXY_THROUGH_DJANGO=false
# VITE_FORMULARIOS_API_BASE=https://api.bwa.global:3334/api/formularios
# VITE_FORMULARIOS_TOKEN_FROM_PORTAL=true
#
# Modo 2 — LAN / HTTP: Django faz proxy (sem CORS). Mesmo host que VITE_API_URL + Token BWA no axios:
# VITE_FORMULARIOS_PROXY_THROUGH_DJANGO=true
# VITE_FORMULARIOS_TOKEN_FROM_PORTAL=false
# (não definir VITE_FORMULARIOS_API_BASE)

VITE_FORMULARIOS_USE_PROXY=false
VITE_FORMULARIOS_PROXY_THROUGH_DJANGO=false
VITE_FORMULARIOS_API_BASE=https://api.bwa.global:3334/api/formularios
VITE_FORMULARIOS_TOKEN_FROM_PORTAL=true
