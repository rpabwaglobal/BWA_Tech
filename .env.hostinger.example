# Copie para `.env` no servidor (raiz do repo, ao lado de docker-compose.yml).
# Build: variáveis VITE_* entram na imagem — alterar exige `docker compose build --no-cache backend`.

# --- DNS público do site (SPA + API + WebSocket no mesmo host) ---
PUBLIC_HOST=tech.bwa.global

# Rede externa partilhada com o Traefik (no outro projeto é `web`)
TRAEFIK_NETWORK=web
TRAEFIK_CERT_RESOLVER=letsencrypt
# Só se o teu Traefik exigir router explícito no HTTPS (opcional):
# TRAEFIK_ENTRYPOINT=websecure

# --- Postgres ---
POSTGRES_DB=bwaproj_db
POSTGRES_USER=bwaproj
POSTGRES_PASSWORD=defina_uma_senha_forte

# --- Django ---
SECRET_KEY=defina_chave_longa_aleatoria
DEBUG=False
ALLOWED_HOSTS=tech.bwa.global,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://tech.bwa.global
CSRF_TRUSTED_ORIGINS=https://tech.bwa.global
BEHIND_HTTPS_PROXY=true

# Portal (backend obtém JWT para proxy de formulários)
PORTAL_BASE_URL=https://api.bwa.global:3334
PORTAL_USERNAME=
PORTAL_PASSWORD=

# --- Build do frontend (Dockerfile / args do compose) ---
VITE_API_URL=https://tech.bwa.global/api
VITE_WS_URL=wss://tech.bwa.global
VITE_FORMULARIOS_USE_PROXY=false
VITE_FORMULARIOS_PROXY_THROUGH_DJANGO=false
VITE_FORMULARIOS_API_BASE=https://api.bwa.global:3334/api/formularios
VITE_FORMULARIOS_TOKEN_FROM_PORTAL=true

# Redis / Channels (padrão do compose)
CHANNEL_LAYER_BACKEND=redis
REDIS_HOST=redis
REDIS_PORT=6379
