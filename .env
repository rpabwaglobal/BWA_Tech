# Raiz do repo — lido pelo Compose (db) e COPIADO para a imagem no Docker build (Django + Vite).
# Sem este ficheiro o `docker compose build` falha. Alterou valores relevantes → `docker compose build --no-cache`.
# Não commitar segredos se o repo for público.
# Domínio público tech.bwa.global; VPS (ex. 187.77.53.184) via Traefik em :443.
POSTGRES_DB=bwaproj_db
POSTGRES_USER=bwaproj
POSTGRES_PASSWORD=bwaproj_secret

# Django — ligação ao Postgres no Docker (o mesmo user/senha que acima)
USE_POSTGRES=true
DB_HOST=db
DB_PORT=5432
DB_NAME=bwaproj_db
DB_USER=bwaproj
DB_PASSWORD=bwaproj_secret
CHANNEL_LAYER_BACKEND=redis
REDIS_HOST=redis
REDIS_PORT=6379
# Senha do Redis — exigida pelo docker-compose (--requirepass). Rotacione antes do próximo deploy.
REDIS_PASSWORD=piJNPToT9z80oYwIiJAU18u7IOBVGG0Cc1Cf5ojKdt8
CELERY_BROKER_URL=redis://:piJNPToT9z80oYwIiJAU18u7IOBVGG0Cc1Cf5ojKdt8@redis:6379/0
CELERY_RESULT_BACKEND=redis://:piJNPToT9z80oYwIiJAU18u7IOBVGG0Cc1Cf5ojKdt8@redis:6379/0

# Django (container backend)
SECRET_KEY=VDweYDciXvFZLHm5xXYYj2iP-PMqJ2iiXW74UY7YnwjPVJjMxBCjARpX4bFzSsVl
DEBUG=False
BEHIND_HTTPS_PROXY=true
PUBLIC_HOST=tech.bwa.global
TRAEFIK_NETWORK=web
TRAEFIK_CERT_RESOLVER=letsencrypt
# Produção: prefer HOST_BIND=127.0.0.1 — tráfego via Traefik no domínio.
# Enquanto a porta 8000 estiver exposta pelo IP público http://187.77.53.184:8000, o Django exige também
# a forma IP:8000 em ALLOWED_HOSTS (header Host inteiro).

HOST_BIND=127.0.0.1
ALLOWED_HOSTS=tech.bwa.global,localhost,127.0.0.1,187.77.53.184,187.77.53.184:8000
CORS_ALLOWED_ORIGINS=https://tech.bwa.global,http://localhost:8000,http://127.0.0.1:8000,http://187.77.53.184:8000,http://10.10.2.34:3000
CSRF_TRUSTED_ORIGINS=https://tech.bwa.global,http://localhost:8000,http://127.0.0.1:8000,http://187.77.53.184:8000,http://10.10.2.34:3000
# Portal — JWT para Suporte (GET /api/portal/formularios-access/ no Django)
PORTAL_BASE_URL=https://api.bwa.global:3334
PORTAL_USERNAME=rpa@bwa.global
PORTAL_PASSWORD=Bwd@2025!!

# Build do frontend na imagem Docker (Kanban = API portal)
VITE_API_URL=https://tech.bwa.global/api
VITE_WS_URL=wss://tech.bwa.global
VITE_FORMULARIOS_USE_PROXY=false
VITE_FORMULARIOS_API_BASE=https://api.bwa.global:3334/api/formularios
VITE_FORMULARIOS_TOKEN_FROM_PORTAL=true
VITE_FORMULARIOS_PROXY_THROUGH_DJANGO=false
