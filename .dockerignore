# Git e IDE
.git
.gitignore
# .env na raiz entra na imagem (Vite + Django); ignora cópias locais do backend
.cursor
*.md
!README.md

# Frontend (será buildado no Docker)
frontend/node_modules
frontend/dist
frontend/.env*
# .env.production é necessário no build — o Vite lê automaticamente durante
# `npx vite build`. Sem ele, VITE_FORMULARIOS_API_BASE fica indefinido e a
# página de Suporte quebra em runtime ("defina VITE_FORMULARIOS_PROXY_THROUGH_DJANGO...").
!frontend/.env.production
frontend/*.log

# Backend
backend/venv
backend/__pycache__
backend/*/__pycache__
backend/*/*/__pycache__
backend/*.pyc
backend/.env
backend/db.sqlite3
backend/staticfiles
backend/media
backend/*.log

# Testes e dev
*.pytest_cache
.coverage
htmlcov
.pytest_cache
test_*.py
*_test.py

